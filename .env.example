# ─────────────────────────────────────────
# Database
# ─────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://symptaai:symptaai_secret@localhost:5432/symptaai
POSTGRES_DB=symptaai
POSTGRES_USER=symptaai
POSTGRES_PASSWORD=symptaai_secret

# ─────────────────────────────────────────
# Redis
# ─────────────────────────────────────────
REDIS_URL=redis://:redis_secret@localhost:6379/0
REDIS_PASSWORD=redis_secret

# ─────────────────────────────────────────
# JWT / Security
# ─────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─────────────────────────────────────────
# OpenAI
# ─────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─────────────────────────────────────────
# ChromaDB
# ─────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=medical_knowledge

# ─────────────────────────────────────────
# Celery
# ─────────────────────────────────────────
CELERY_BROKER_URL=redis://:redis_secret@localhost:6379/0
CELERY_RESULT_BACKEND=redis://:redis_secret@localhost:6379/1

# ─────────────────────────────────────────
# Application
# ─────────────────────────────────────────
APP_NAME=SymptaAI
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=20

# ─────────────────────────────────────────
# Monitoring (optional)
# ─────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ─────────────────────────────────────────
# Frontend
# ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
